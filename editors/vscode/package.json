{
  "name": "dotgraft",
  "displayName": "Graft Recipes",
  "description": "Syntax highlighting, snippets, schema, and helpers for .graft image recipes.",
  "version": "0.1.0",
  "publisher": "briancorbin",
  "license": "MIT",
  "icon": "icon.png",
  "repository": { "type": "git", "url": "https://github.com/briancorbin/graft", "directory": "editors/vscode" },
  "homepage": "https://github.com/briancorbin/graft#readme",
  "bugs": { "url": "https://github.com/briancorbin/graft/issues" },
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Snippets"],
  "keywords": ["graft", "tart", "ci", "github actions", "macos", "vm", "image", "devcontainer"],
  "galleryBanner": { "color": "#1f2024", "theme": "dark" },
  "pricing": "Free",
  "qna": false,
  "main": "./extension.js",
  "activationEvents": ["onLanguage:graft"],
  "contributes": {
    "languages": [
      {
        "id": "graft",
        "aliases": ["Graft", "graft"],
        "extensions": [".graft"],
        "filenames": ["Graftfile"],
        "configuration": "./language-configuration.json",
        "icon": { "light": "./icons/graft-light.svg", "dark": "./icons/graft-dark.svg" }
      }
    ],
    "grammars": [
      {
        "language": "graft",
        "scopeName": "source.graft",
        "path": "./syntaxes/graft.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.shellscript": "shellscript"
        }
      }
    ],
    "snippets": [
      { "language": "graft", "path": "./snippets/graft.code-snippets" }
    ],
    "commands": [
      {
        "command": "graft.render",
        "title": "Graft: Render compiled provisioning script",
        "icon": "$(eye)"
      },
      {
        "command": "graft.build",
        "title": "Graft: Build image from this recipe"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "graft.render",
          "when": "resourceLangId == graft",
          "group": "navigation"
        }
      ]
    }
  }
}
